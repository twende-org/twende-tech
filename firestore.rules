rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- COLLECTIONS ---

    // User Profiles: Users read self, Admins read/write all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Projects: Public read, Admin write, Assigned Client read
    match /projects/{projectId} {
      allow read: if true; // Public portfolio
      allow write: if isAdmin();
      // Logic for client dashboard specific filtering is handled by 'allow read: if true'
      // but if we wanted private projects, we would add:
      // allow read: if isAdmin() || (resource.data.clientId == request.auth.uid);
    }

    // Testimonials: Public read, Admin write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messages: Public create (Contact Form), Admin read/write
    match /messages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Leads: Public create (Inquiry Form), Admin read/write
    match /leads/{leadId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    // Support Tickets: Client create/read-own, Admin read/write-all
    match /tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin() || (resource.data.clientId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Live Chats: Client read/write own thread, Admin all
    match /chats/{clientId} {
      allow read, write: if isAdmin() || isOwner(clientId);
      
      match /messages/{messageId} {
        allow read, write: if isAdmin() || isOwner(clientId);
      }
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
